<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.CircleToSearch" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_blue_subtle</item>
        <item name="colorOnPrimaryContainer">@color/brand_blue</item>
        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surfaces -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_elevated</item>

        <!-- Background — MUST use android: prefix; bare 'colorBackground' is not a valid Material3 attr -->
        <item name="android:colorBackground">@color/bg_primary</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Ripple color -->
        <item name="colorControlHighlight">#1A2484FF</item>
    </style>

    <!-- Section header text style (used in LinearLayout/TextView directly) -->
    <style name="SectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/section_header</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Switch row inside a card -->
    <style name="SwitchRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

</resources>
